<h1 class="app-main-title">{{ translate('Projects') }} > {{ translate('Assign tasks to milestone') }}</h1>

<hblreact-table
  string:model="Hubleto/App/Community/Projects/Models/MilestoneTask"
  string:tag="table-milestones-tasks"
  int:record-id="{{ viewParams.recordId }}"
  json:custom-endpoint-params='{"idTask": {{ viewParams.idTask ?? 0 }} }'
  string:fulltext-search='{{ viewParams.q }}'
  json:column-search='{{ viewParams.search|json_encode }}'
  json:filters='{{ viewParams.filters|json_encode }}'
  string:form-active-tab-uid='{{ viewParams.tab }}'
></hblreact-table