<div class="p-2 text-sm font-normal">
  <div class="flex flex-col">
    <div class="flex gap-2">
      <div class="text-primary">{{ item.OWNER.nick }}</div>
      <div class="text-gray-400 text-nowrap">
        {% for c in item.CAMPAIGNS %}
          {{ c.CAMPAIGN.name }}
        {% endfor %}
      </div>
    </div>
    <div class="font-bold">
      {{ item.title }}
      {{ item.email }}
      {{ item.phone }}
    </div>
  </div>
</div>

