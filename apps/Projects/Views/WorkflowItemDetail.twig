<div class="p-2 text-sm font-normal">
  <div class="flex justify-between w-full">
    <div class="flex flex-col truncate gap-1">
      <div class="flex flex-row gap-2">
        <div class="text-primary">{{ item.PROJECT_MANAGER.nick }}</div>
        <div class="text-gray-400">{{ item.CUSTOMER.name }}</div>
      </div>
      <div class="font-bold">{{ item.identifier }} {{ item.title }}</div>
      {% if item.MILESTONES|length <= 0 %}
        <div>{{ translate('Project has no milestones.') }}</div>
      {% else %}
        <div class="list dense">
          {% for m in item.MILESTONES %}
            {% if not m.is_closed %} 
              <a
                class="btn btn-list-item btn-transparent {{ (m.REPORTS|first).progress_percent == 100 ? "text-gray-600" : "text-violet-600" }}"
                href="{{ hubleto.env().projectUrl }}/projects/milestones/{{ m.id }}"
                target="_blank"
              >
                <span class="icon"><i class="fas fa-calendar-check"></i></span>
                <span class="text">
                  {{ hubleto.locale().formatDateShort(m.date_due) }}
                  {{ m.title }}
                  {% if m.REPORTS|length > 0 %}
                    ({{ translate('progress') }} {{ (m.REPORTS|first).progress_percent }} % {{ translate('reported on') }} {{ hubleto.locale().formatDateShort((m.REPORTS|first).date_report) }})
                  {% else %}
                    ({{ translate('no report yet') }})
                  {% endif %}
                </span>
              </a>
            {% endif %}
            {% if m.is_closed %}
              <div class="btn btn-transparent btn-list-item"><span class="text line-through">{{ hubleto.locale().formatDateShort(m.date_due) }} {{ m.title }}</span></div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
      {% for t in item.TASKS %}
        {% if t.TASK.identifier > 0 %}
          <div class="text-sm text-primary">{{ t.TASK.identifier }} {{ t.TASK.title }}</div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
