<div class="card-header rounded flex flex-col p-2 text-sm font-normal">
  <div class="flex justify-between w-full">
    <div class="flex flex-col truncate">
      <div class="flex gap-2">
        {% for c in item.CAMPAIGNS %}
          <div class="badge badge-lime badge-small">{{ c.CAMPAIGN.name }}</div>
        {% endfor %}
      </div>
      <div class="font-bold">
        {{ item.email }}
        {{ item.phone }}
      </div>
      <div class="text-primary">{{ item.OWNER.email }}</div>
    </div>
  </div>
</div>

