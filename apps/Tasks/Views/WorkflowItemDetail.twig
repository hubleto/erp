<div class="flex flex-col p-2 text-sm font-normal">
  <div class="flex gap-2">
    <div class="bg-gray-50 p-1">
      <div class="text-primary">{{ item.DEVELOPER.nick ?? (item.DEVELOPER.email ?? '<div class="text-red-800 text-xs">?</div>') }}</div>
      <div class="text-primary">{{ item.TESTER.nick ?? (item.TESTER.email ?? '<div class="text-red-800 text-xs">?</div>') }}</div>
    </div>
    <div>
      <div class="text-gray-400 text-nowrap">{{ item.CUSTOMER.name ?? '?' }}</div>
      <div class="font-bold">{{ item.identifier }} {{ item.title }}</div>
    </div>
  </div>
  <div>
    <span
      class="badge badge-info text-xs border border-blue-200 inline-block text-nowrap"
      style="
        width:{{ item.virt_worked_hours/2 }}px;
        max-width:360px;
        overflow: visible;
      "
    >
      <i class="fas fa-clock mr-2"></i>
      {{ hubleto.locale().formatNumber(item.virt_worked_hours, 2) }} h
    </span>
  </div>
  {% for t in item.TODO %}
    {% if not t.is_closed %}
      <div class="text-sm text-yellow-400">{{ t.todo }}</div>
    {% endif %}
  {% endfor %}
</div>
